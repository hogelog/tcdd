#!/bin/bash

if [ "${1:-}" == "init" ]; then
  echo "source \"$0\""
  exit
fi

cddfile=~/.cdd

touch "$cddfile"

function cdd_cd() {
  # An `IFS=` prefix on a `local` assignment does not affect the word
  # splitting of its right-hand side, so the array would split on the
  # default IFS and break paths/names containing spaces.
  local windows
  mapfile -t windows < "$cddfile"
  local target="$1"
  local window
  local dir=""
  for window in "${windows[@]}"
  do
    if [[ "${window%%:*}" == "$target" ]]; then
      dir="${window#*:}"
      break
    fi
  done
  if [ -z "$dir" ]; then
    echo "cdd: no such entry: $target" >&2
    return 1
  fi
  echo "cd $dir"
  cd "$dir"
}

function cdd_list() {
  cat "$cddfile"
}

function cdd_add() {
  local name="${1:-$(basename "$(pwd)")}"
  cdd_rec "$name" "$(pwd)"
  while IFS= read -r line; do
    [[ "${line%%:*}" == "$name" ]] && echo "$line"
  done < "$cddfile"
}

function cdd() {
  case "${1:-}" in
    "list") cdd_list ;;
    "") cdd_list ;;
    "add") cdd_add "${2:-}" ;;
    *) cdd_cd "$1" ;;
  esac
}

function cdd_rec() {
  local newline="$1:$2"
  local found=0
  local tmpfile
  # PROMPT_COMMAND fires per prompt, so several windows can record
  # concurrently; an in-place rewrite (or a shared temp file) tears
  # ~/.cdd under that race.
  tmpfile=$(mktemp "${cddfile}.XXXXXX") || return 1

  while IFS= read -r line; do
    if [[ "${line%%:*}" == "$1" ]]; then
      echo "$newline" >> "$tmpfile"
      found=1
    else
      echo "$line" >> "$tmpfile"
    fi
  done < "$cddfile"

  if [ $found -eq 0 ]; then
    echo "$newline" >> "$tmpfile"
  fi

  # Simple bubble sort for small files
  local lines n i j tmp
  mapfile -t lines < "$tmpfile"
  n=${#lines[@]}
  for ((i=0; i<n-1; i++)); do
    for ((j=0; j<n-i-1; j++)); do
      if [[ "${lines[j]}" > "${lines[j+1]}" ]]; then
        tmp="${lines[j]}"
        lines[j]="${lines[j+1]}"
        lines[j+1]="$tmp"
      fi
    done
  done

  printf '%s\n' "${lines[@]}" > "$tmpfile"
  mv -f "$tmpfile" "$cddfile"
}

# Unset (not "") so the first prompt is distinguishable from a later cd.
function tcdd_record_pwd() {
  # `if`, not early `return`: a skipped body must still yield 0 for the next $?.
  if [ -n "${TMUX:-}" ]; then
    if [ -z "${TCDD_LAST_PWD+set}" ]; then
      # First prompt = the window's untouched start dir (often $HOME). Seed
      # without recording; also dodges a stale cd in shared history below.
      TCDD_LAST_PWD="$PWD"
    else
      local record=""
      if [ "$PWD" != "$TCDD_LAST_PWD" ]; then
        record=1
      else
        # Also catch an explicit cd that didn't move PWD (argless cd already at
        # $HOME). HISTTIMEFORMAT= strips a configured timestamp prefix.
        local hist cmd
        hist=$(HISTTIMEFORMAT= history 1)
        read -r _ cmd <<< "$hist"
        [[ "$cmd" == "cd" || "$cmd" == "cd "* ]] && record=1
      fi
      if [ -n "$record" ]; then
        # Re-resolve each time: a cached index goes stale on renumber, and the
        # pane (not active window) avoids crediting a background pane's prompt.
        local current_window
        current_window=$(tmux display-message -p -t "${TMUX_PANE:-}" '#I' 2>/dev/null)
        if [ -n "$current_window" ]; then
          cdd_rec "$current_window" "$PWD"
          TCDD_LAST_PWD="$PWD"
        fi
      fi
    fi
  fi
}

# Use PROMPT_COMMAND to track directory changes
if [[ ! "${PROMPT_COMMAND:-}" =~ tcdd_record_pwd ]]; then
  PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND;}tcdd_record_pwd"
fi

__cdd_init_completion()
{
  COMPREPLY=()
  _get_comp_words_by_ref cur prev words cword
}

function _cdd_bash() {
  local cur prev words cword split

  if declare -F _init_completion >/dev/null 2>&1; then
    _init_completion
  else
    __cdd_init_completion
  fi

  case $cword in
    1)
      COMPREPLY=( $(compgen -W "$(echo add && echo list && while IFS=: read -r key value; do echo "$key"; done < "$cddfile")" -- "$cur") )
      ;;
  esac
}

if type complete >/dev/null; then
   complete -F _cdd_bash cdd
fi
